# Local testing: serve pack with ./serve-resourcepack.sh and use this URL.
# Set LOCAL_RESOURCE_PACK=false to host from the GitHub repo (via jsDelivr CDN).
LOCAL_RESOURCE_PACK=false
LOCAL_RESOURCE_PACK_URL=http://127.0.0.1:8080/BladePack.zip

# Pack zip lives in this GitHub repo. CDN: jsdelivr (default) or raw.
RESOURCE_PACK_GITHUB_REPO=PrincessXVII/blade-server
RESOURCE_PACK_GITHUB_PATH=resourcepack/BladePack.zip
RESOURCE_PACK_CDN=jsdelivr
